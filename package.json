{
  "name": "desh-monorepo",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "packageManager": "pnpm@9.0.0",
  "scripts": {
    "dev": "pnpm -r --parallel --filter \"@desh/*\" run dev",
    "dev:web": "pnpm --filter @desh/web dev",
    "dev:api": "pnpm --filter @desh/api dev",
    "build": "pnpm -r --filter \"@desh/*\" run build",
    "lint": "pnpm -r --filter \"@desh/*\" run lint",
    "typecheck": "pnpm -r --filter \"@desh/*\" run typecheck",
    "test": "pnpm -r --filter \"@desh/*\" run test",
    "db:generate": "pnpm --filter @desh/database run generate",
    "db:migrate": "pnpm --filter @desh/database run migrate",
    "db:seed": "pnpm --filter @desh/database run seed"
  },
  "devDependencies": {
    "@eslint/js": "^9.32.0",
    "eslint": "^9.32.0",
    "prettier": "^3.3.3",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.38.0"
  }
}
