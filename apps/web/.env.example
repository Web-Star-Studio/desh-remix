# Backend API
VITE_API_BASE_URL=http://localhost:3001

# AWS Cognito (target auth provider)
VITE_COGNITO_USER_POOL_ID=
VITE_COGNITO_CLIENT_ID=
# Cognito hosted UI domain — required for OAuth (Google) sign-in.
# Found in AWS Console: User pool -> App integration -> Cognito domain
# e.g. desh-dev.auth.sa-east-1.amazoncognito.com
VITE_COGNITO_DOMAIN=

# Legacy Supabase — only used by feature areas not yet migrated. Will be
# removed once every Supabase-touching feature is gone or migrated.
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=
VITE_SUPABASE_PROJECT_ID=
