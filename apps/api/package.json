{
  "name": "@desh/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch --env-file=.env src/index.ts",
    "build": "tsup src/index.ts --format esm --dts --clean",
    "start": "node --env-file=.env dist/index.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "dev:reset": "tsx --env-file=.env scripts/dev-reset.ts",
    "mcp:repair": "tsx --env-file=.env scripts/mcp-repair.ts"
  },
  "dependencies": {
    "@aws-sdk/client-kms": "^3.1037.0",
    "@aws-sdk/client-s3": "^3.1037.0",
    "@aws-sdk/s3-request-presigner": "^3.1037.0",
    "@composio/core": "^0.6.11",
    "@desh/database": "workspace:*",
    "@desh/shared": "workspace:*",
    "@fastify/cors": "^10.0.1",
    "@fastify/sensible": "^6.0.1",
    "aws-jwt-verify": "^5.1.0",
    "drizzle-orm": "^0.36.4",
    "fastify": "^5.1.0",
    "fastify-plugin": "^5.0.1",
    "fastify-type-provider-zod": "^4.0.2",
    "jose": "^5.9.6",
    "pg-boss": "^12.18.0",
    "postgres": "^3.4.4",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@testcontainers/postgresql": "^11.14.0",
    "@types/node": "^22.16.5",
    "aws-sdk-client-mock": "^4.1.0",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  }
}
