NODE_ENV=development
PORT=3001

# Postgres for the new schema. Run `pnpm db:migrate` after setting this.
DATABASE_URL=postgres://desh:desh@localhost:5433/desh_dev

# AWS Cognito — primary auth provider. JWT verification via JWKS, no shared secret.
# Create a User Pool in the AWS Console and grab these:
COGNITO_REGION=us-east-1
COGNITO_USER_POOL_ID=
COGNITO_CLIENT_ID=

# AWS KMS — envelope encryption for workspace_credentials (Composio tokens etc.)
# KMS_KEY_ID is the master key ARN/alias. AWS_REGION must match the key's region.
# Without these, /workspaces/:id/credentials returns 503.
AWS_REGION=us-east-1
KMS_KEY_ID=

# AWS S3 — file storage. Bucket name is global; pick a project-prefixed name
# (desh-private-dev / desh-private-prod). Without AWS_S3_BUCKET, the /files
# routes return 503. Credentials follow the SDK default chain unless the
# explicit pair is set (useful for local dev without ~/.aws/credentials).
AWS_S3_BUCKET=
AWS_S3_ACCESS_KEY_ID=
AWS_S3_SECRET_ACCESS_KEY=
# Presigned URL TTL in seconds (default 60). Short by design — SPA re-requests.
AWS_S3_PRESIGN_TTL_SECONDS=60

# Composio — replaces composio-proxy + integrations-connect edge fns.
# Get an API key at https://app.composio.dev/. The redirect URL must match the
# one registered in Composio's app settings (it's where users are sent after
# OAuth completes).
COMPOSIO_API_KEY=
COMPOSIO_REDIRECT_URL="http://localhost:8080/integrations?composio_callback=true"
# Shared secret for verifying Composio webhook signatures (HMAC-SHA256 over
# `<timestamp>.<body>`). Generate ≥16 chars and paste the same value in
# Composio's webhook configuration. If unset, /composio/webhook returns 503.
COMPOSIO_WEBHOOK_SECRET=

# Zernio (a.k.a. "Late") — first-party WhatsApp Business + social provider
# powering /social and /messages. The agent reaches Zernio capabilities
# exclusively through the Desh MCP's Zernio-backed tools (social_*,
# whatsapp_*, inbox_*, media_*); each handler injects `profileId` from
# `workspaces.zernio_profile_id` server-side. We do NOT mount Zernio's
# hosted MCP at mcp.zernio.com directly — its API key is shared across
# workspaces with no per-profile auth scoping.
# Get a key at https://zernio.com/dashboard/api-keys.
ZERNIO_API_KEY=
# REST endpoint (default is public). Override only if Zernio self-hosts.
ZERNIO_API_BASE=https://zernio.com/api/v1
# Shared secret for verifying Zernio webhook signatures. The handler tries
# HMAC-SHA256(`<ts>.<rawBody>`) first and falls back to plain shared-secret
# comparison if no `X-Zernio-Signature-Timestamp` header is present (legacy
# late-proxy behaviour). When unset, /zernio/webhook returns 503.
ZERNIO_WEBHOOK_SECRET=

# OpenRouter (platform-managed for MVP per PRD).
# Required for the Hermes gateway to actually answer prompts. Without it,
# gateway start succeeds but the first OpenRouter call fails. The supervisor
# will return 503 agent_unavailable on POST /messages.
OPENROUTER_API_KEY=

# Hermes integration ----------------------------------------------------------
# Path to the hermes binary. Defaults to "hermes" (must be on PATH).
# Override with an absolute path if installed elsewhere.
HERMES_BIN=hermes

# Parent directory where per-workspace HERMES_HOME directories are written.
# Default: <repo>/.hermes-profiles
# Each workspace gets its own ws_<uuid>/ subdir with config.yaml + .env.
HERMES_HOME_BASE=

# Port pool for per-workspace Hermes gateways. apps/api allocates a port
# from this range and writes it into agent_profiles.hermes_port.
HERMES_PORT_RANGE_START=8650
HERMES_PORT_RANGE_END=8800

# Public URL apps/api exposes for Hermes callbacks (where the gateways POST
# their assistant events back). Match the value the SPA uses to reach apps/api.
HERMES_CALLBACK_BASE_URL=http://127.0.0.1:3001

# Lazy gateway lifecycle: gateways start on the first message in a workspace
# and stop after this many ms of no inbound traffic. Default 10 minutes.
HERMES_IDLE_TIMEOUT_MS=600000
# How often the supervisor checks for idle gateways. Default 1 minute.
HERMES_IDLE_SWEEP_MS=60000
# How long to wait for a freshly-spawned gateway to pass /health before
# treating the start as failed. Default 15 seconds.
HERMES_HEALTH_TIMEOUT_MS=15000

# Shared bearer secret apps/api accepts on /internal/hermes/events for
# dev-mode simplicity (per-workspace callback secrets are also accepted).
INTERNAL_CALLBACK_TOKEN=replace-me-with-a-random-32-byte-hex
