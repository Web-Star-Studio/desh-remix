NODE_ENV=development
PORT=3001

# Postgres for the new schema. Run `pnpm db:migrate` after setting this.
DATABASE_URL=postgres://desh:desh@localhost:5433/desh_dev

# AWS Cognito — target auth provider. JWT verification via JWKS, no shared secret.
# Create a User Pool in the AWS Console and grab these:
COGNITO_REGION=us-east-1
COGNITO_USER_POOL_ID=
COGNITO_CLIENT_ID=

# Supabase JWT bridge — kept ONLY during the auth migration so the SPA keeps
# working until the Cognito swap. Remove once Cognito is live.
# Found in Supabase dashboard under Project Settings -> API -> JWT Secret
# (NOT the anon/publishable key).
SUPABASE_JWT_SECRET=

# OpenRouter (platform-managed for MVP per PRD).
OPENROUTER_API_KEY=

# Internal token Hermes adapters use to authenticate callbacks to /internal/hermes/events.
INTERNAL_CALLBACK_TOKEN=replace-me-with-a-random-32-byte-hex

# Template URL for talking to a per-workspace Hermes gateway.
# {port} is replaced with the workspace's allocated gateway port.
HERMES_BASE_URL_TEMPLATE=http://127.0.0.1:{port}
